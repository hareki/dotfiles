# Updates
auto-update = download
auto-update-channel = stable

# UI
theme = Catppuccin Mocha
macos-titlebar-style = hidden
mouse-hide-while-typing = true
copy-on-select = clipboard
bell-features = system, attention, title

adjust-cell-height = 31%
window-padding-balance = true
window-padding-x = 6
window-padding-y = 3

# Font
font-size = 19.0
adjust-icon-height = 15%
font-style = SemiBold
font-family = Maple Mono NF
font-feature = +calt, +liga, -zero, -ss02
font-style-bold  = ExtraBold
font-style-italic  = SemiBold Italic
font-style-bold-italic  = ExtraBold Italic

background-image = background-images/stack-blur-50-planet_with_sunrise.png
background-image-opacity = 0.055
background-image-fit = cover

# Shell & Cursor
shell-integration = zsh

# Cursor feature will mess up the cursor shape I set in zsh vi-mode
shell-integration-features = no-cursor

cursor-style = bar
cursor-style-blink = true

# Cursor
cursor-color = #cdd6f4	
cursor-text = #11111b
# custom-shader = shaders/cursor_trail.glsl

# Keybindings
# Mapped heavily for tmux + neovim + zsh workflows
# ----------------------

macos-option-as-alt = true
# Remap cmd + keys to alt + keys so that tmux can understand them.
# They was previously esc:<key> but .tmux.conf does not support those key sequences correctly...

# Special sequences for zsh keybinding to consume in keymaps.zsh or in neovim, since we can't normally bind shift key
keybind = cmd+shift+o=text:\x1b[1;6O
keybind = ctrl+shift+y=text:\x1b[1;6Y
# Ctrl+Shift+F4 escape sequences
keybind = cmd+shift+s=text:\x1b[1;6S
# jake-stewart/multicursor.nvim toggle, Ctrl+Shift+F1 escape sequences
keybind = ctrl+m=text:\x1b[1;6P

# Neovim doesn't recognize text:\x1b[1;6W
keybind = cmd+shift+w=text:\x1b[1;6F

# zsh autin-search
keybind = cmd+f=text:\x1bf

keybind = cmd+r=text:\x1br
keybind = cmd+space=text:\x1b\x20
keybind = cmd+s=text:\x1bs 
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# Tmux window navigation (prev/next). cmd+[ / cmd+] can't tunnel through
# alt+[ / alt+] because ESC-[ is the CSI introducer (start of a control
# sequence), so route through free alt keys instead. See tmux.keymaps.conf.
keybind = cmd+[=text:\x1bh
keybind = cmd+]=text:\x1bl

# Close buffer keymap in Neovim
keybind = cmd+w=text:\x1bw
# claudecode.nvim toggle
keybind = cmd+a=text:\x1ba
# opencode command palette
keybind = cmd+p=text:\x1bp

# Toggle floating nvim terminal
keybind = cmd+t=text:\x1bt

# Snacks lazygit toggle
keybind = cmd+g=text:\x1bg
# Toggle terminal tab (Nvim)
keybind = cmd+shift+t=text:\x1bT

# Tmux prefix
keybind = cmd+d=text:\x1bd

# Tmux pane navigation 
keybind = cmd+m=text:\x1bm
keybind = cmd+n=text:\x1bn
keybind = cmd+e=text:\x1be
keybind = cmd+i=text:\x1bi

# Shift enter to insert new line in claude/copilot
keybind = shift+enter=text:\x1b\r
