#!/bin/zsh

build() {
  local -a targets=(atuin lazygit television tmux)

  case "$1" in
    --list) print -l all $targets; return 0 ;;
    --help|"")
      print "Usage: build <target>"
      print "Available targets: all, ${(j:, :)targets}"
      return 0
      ;;
    all)
      for target in $targets; do
        print -P "\n%B%F{blue}======== Building $target ========%f%b"
        (cd ~/Repositories/personal/$target && git pull && build $target) || print -P "%F{red}==> Failed to build $target%f" >&2
      done
      ;;
    atuin)      cargo install --locked --path crates/atuin ;;
    lazygit)    go install ;;
    television) cargo install --locked --path . ;;
    tmux)
        sh autogen.sh \
        && ./configure --enable-utf8proc \
        && make clean \
        && make \
        && sudo make install
      ;;
    *)
      print "Unknown target: $1" >&2
      build --help
      return 1
      ;;
  esac
}
