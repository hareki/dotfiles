#!/bin/zsh

# alias yay='brew update && brew upgrade && brew autoremove && antidote update && npm update -g && gem update'
yay() {
  brew update && brew upgrade && brew autoremove \
    && antidote update \
    && mise install \
    && mise upgrade \
    && ~/.tmux/plugins/tpm/bin/clean_plugins \
    && ~/.tmux/plugins/tpm/bin/install_plugins \
    && ~/.tmux/plugins/tpm/bin/update_plugins all \
    && npm update -g \
    && gem update
}
